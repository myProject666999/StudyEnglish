<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.english.mapper.QuoteMapper">

    <resultMap id="BaseResultMap" type="com.english.entity.Quote">
        <id column="id" property="id"/>
        <result column="content" property="content"/>
        <result column="content_cn" property="contentCn"/>
        <result column="author" property="author"/>
        <result column="source" property="source"/>
        <result column="is_daily" property="isDaily"/>
        <result column="daily_date" property="dailyDate"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, content, content_cn, author, source, is_daily, daily_date, status, create_time, update_time
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM t_quote
        WHERE id = #{id}
    </select>

    <select id="selectDaily" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM t_quote
        WHERE is_daily = 1 AND status = 1
        ORDER BY daily_date DESC
        LIMIT 1
    </select>

    <select id="selectRandom" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM t_quote
        WHERE status = 1
        ORDER BY RAND()
        LIMIT 1
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM t_quote
        WHERE status = 1
        ORDER BY create_time DESC
    </select>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM t_quote
        WHERE 1=1
        <if test="keyword != null and keyword != ''">
            AND (content LIKE CONCAT('%', #{keyword}, '%') 
            OR content_cn LIKE CONCAT('%', #{keyword}, '%')
            OR author LIKE CONCAT('%', #{keyword}, '%'))
        </if>
        ORDER BY create_time DESC
    </select>

    <insert id="insert" parameterType="com.english.entity.Quote" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_quote (content, content_cn, author, source, is_daily, daily_date, status)
        VALUES (#{content}, #{contentCn}, #{author}, #{source}, #{isDaily}, #{dailyDate}, #{status})
    </insert>

    <update id="update" parameterType="com.english.entity.Quote">
        UPDATE t_quote
        <set>
            <if test="content != null">content = #{content},</if>
            <if test="contentCn != null">content_cn = #{contentCn},</if>
            <if test="author != null">author = #{author},</if>
            <if test="source != null">source = #{source},</if>
            <if test="isDaily != null">is_daily = #{isDaily},</if>
            <if test="dailyDate != null">daily_date = #{dailyDate},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM t_quote WHERE id = #{id}
    </delete>

    <update id="updateDailyStatus">
        UPDATE t_quote SET is_daily = 0 WHERE is_daily = 1
    </update>

</mapper>
